import numpy as np
import matplotlib.pyplot as plt

from htbm_py.bfgs import bfgs

## Define problem ########################

from torch import nn
from test_functions.simple_NN import simple_NN
from test_functions.simple_NN import loss_unreg
from test_functions.simple_NN import visualize
class NeuralNetwork(nn.Module):
    def __init__(self):
        super().__init__()
        self.linear_relu_stack = nn.Sequential(
            nn.Linear(1, 3),
            nn.ReLU(),
            nn.Linear(3, 2),
            nn.ReLU(),
            nn.Linear(2, 1),
        )

    def forward(self, x):
        logits = self.linear_relu_stack(x)
        return logits
    
model = NeuralNetwork().to("cpu")
problem_data = simple_NN(model,0.001)

n = problem_data.x0.shape[0]

problem_data.x0 = 6*np.random.rand(n) - 3
