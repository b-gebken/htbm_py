## Set the parameters for the method ############

algo_options = {
    'N_iter': 1000,
    'H0': np.eye(n),
    'c1': 0.0001,
    'c2': 0.5,
    'reset_period': np.inf,
    'step_threshold': 10**(-10),
    'descent_threshold': 10**(-10),
    'disp_flag': 2
}

result_bfgs = bfgs(problem_data,algo_options)

## Visualize NN ########################

