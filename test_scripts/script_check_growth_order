# A script for approximating the growth order by randomly sampling points near
# the minimum. (Becomes worse the larger n.)

import numpy as np
import matplotlib.pyplot as plt
import time

from htbm_py.htbm import sample_hypersphere
from htbm_py.dgs import smallest_norm_element

## Define problem ########################

## loss_NN_lsq
from torch import nn
from htbm_py.test_functions.loss_NN_lsq import loss_NN_lsq

class NeuralNetwork(nn.Module):
    def __init__(self):
        super().__init__()
        self.linear_relu_stack = nn.Sequential(
            nn.Linear(1, 3),
            nn.ReLU(),
            nn.Linear(3, 2),
            nn.ReLU(),
            nn.Linear(2, 1),
        )

    def forward(self, x):
        logits = self.linear_relu_stack(x)
        return logits
    
model = NeuralNetwork().to("cpu")

reg_param = 0.0001
N_data = 20
problem_data = loss_NN_lsq(model,reg_param,N_data)

n = problem_data.x0.shape[0]

## Define mininum and radius for sampling 

x = np.array([-1.2737644744674492e+00,  1.1316896534481780e+00,
       -6.0802500315902586e-01,  1.1045578177326596e+00,
        2.3678135927411392e-01, -3.2709127111716396e-01,
       -1.6562065817714948e+00, -6.9833969169552712e-01,
       0,  7.2211570940229886e-01,
       -6.7013132103765727e-01, -9.3511627427513966e-01,
        1.2770464483111723e+00, -6.8141573028809174e-02,
        3.6315927217865878e+00,  2.3955048787183748e+00,
       -1.3858824895083590e+00])

N = 500
eps = 0.000001
p = 2

f = problem_data.oracle[0]
grad_f = problem_data.oracle[1]
f_x = f(x)
growth_arr = np.zeros(N)
grad_mat = np.zeros([N,n])

## Approximate growth order ##############

np.random.seed(0)
start_time = time.time()
for i in range(N):
    x_sample = x + eps*(2*sample_hypersphere(n)-1)
    f_x_sample = f(x_sample)

    growth_arr[i] = (f_x_sample - f_x)/(np.linalg.norm(x_sample - x)**p)

    grad_mat[i,:] = grad_f(x_sample)

end_time = time.time()

## Show results ##########################

print('Min. growth order: ',np.min(growth_arr))
print('Time: ',end_time - start_time)
print('Min. norm grad.: ',np.min([np.linalg.norm(grad_mat[i,:]) for i in range(N)]))
print('Max. norm grad.: ',np.max([np.linalg.norm(grad_mat[i,:]) for i in range(N)]))

g_eps = smallest_norm_element([grad_mat[i,:] for i in range(N)])
print('||g_eps||: ', np.linalg.norm(g_eps))
print('||grad_f(x)||: ', np.linalg.norm(grad_f(x)))

[plt.plot(grad_mat[:,i],'o-') for i in range(n)]

plt.show()