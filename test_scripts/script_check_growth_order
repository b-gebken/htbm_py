import numpy as np
import matplotlib.pyplot as plt
import time

from htbm_py.htbm import sample_hypersphere

## Define problem ########################

## simple NN
from torch import nn
from test_functions.simple_NN import simple_NN
from test_functions.simple_NN import loss_unreg
from test_functions.simple_NN import visualize
class NeuralNetwork(nn.Module):
    def __init__(self):
        super().__init__()
        self.linear_relu_stack = nn.Sequential(
            nn.Linear(1, 3),
            nn.ReLU(),
            nn.Linear(3, 2),
            nn.ReLU(),
            nn.Linear(2, 1),
        )

    def forward(self, x):
        logits = self.linear_relu_stack(x)
        return logits
    
model = NeuralNetwork().to("cpu")
problem_data = simple_NN(model,0.001)

n = problem_data.x0.shape[0]

##

x = np.array([-3.31027137e-05,  1.30121360e+00,  8.83305740e-01, -6.61817766e-06,
       -5.65883211e-01,  8.19663381e-01, -1.02478778e-05, -1.78793677e+00,
        9.29823338e-01, -3.39167521e-05,  7.94169060e-02, -6.74663746e-01,
       -4.80340780e-01,  1.09053386e+00, -3.21685127e+00,  1.86998978e+00,
       -1.26323430e-01])

N = 1000
eps = 0.0001
p = 2

f = problem_data.oracle[0]
grad_f = problem_data.oracle[1]
f_x = f(x)
growth_arr = np.zeros(N)
grad_mat = np.zeros([N,n])

np.random.seed(0)

start_time = time.time()
for i in range(N):
    x_sample = x + eps*(2*sample_hypersphere(n)-1)
    f_x_sample = f(x_sample)

    growth_arr[i] = (f_x_sample - f_x)/(np.linalg.norm(x_sample - x)**p)

    grad_mat[i,:] = grad_f(x_sample)

end_time = time.time()

print('Min growth order: ',np.min(growth_arr))
print('Time: ',end_time - start_time)
print('Min. norm: ',np.min([np.linalg.norm(grad_mat[i,:]) for i in range(N)]))
print('Max. norm: ',np.max([np.linalg.norm(grad_mat[i,:]) for i in range(N)]))

# sort_inds = np.argsort(grad_mat[:,1])
# [plt.plot(grad_mat[sort_inds,i],'o-') for i in range(n)]

[plt.plot(np.sort(grad_mat[:,i]),'o-') for i in range(n)]

plt.show()